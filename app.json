{
  "expo": {
    "name": "TinyVault",
    "slug": "tinyvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "tinyvault",
    "backgroundColor": "#DFFFD6",
    "splash": {
      "backgroundColor": "#DFFFD6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tinyvault.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#DFFFD6",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.tinyvault.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
